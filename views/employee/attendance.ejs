  <script>
          function disableCourseSelection() {
            document.getElementById('courseSelction').disabled = true;
            document.getElementById('changeCourseButton').classList.remove('d-none');
          }

          function enableCourseSelection() {
            document.getElementById('courseSelction').disabled = false;
            document.getElementById('changeCourseButton').classList.add('d-none');
          }
          
          // Handle payment info alert dismissal
          document.addEventListener('DOMContentLoaded', function() {
            const paymentInfoAlert = document.getElementById('paymentInfoAlert');
            
            // Check if user has previously dismissed the alert
            if (localStorage.getItem('paymentInfoDismissed') === 'true') {
              paymentInfoAlert.style.display = 'none';
            }
            
            // Handle alert dismissal
            paymentInfoAlert.addEventListener('closed.bs.alert', function() {
              localStorage.setItem('paymentInfoDismissed', 'true');
            });
          });
          
          // Fixed amount checkbox handler
          document.addEventListener('DOMContentLoaded', function() {
            const fixedAmountCheck = document.getElementById('fixedAmountCheck');
            const fixedAmount = document.getElementById('fixedAmount');
            
            fixedAmountCheck.addEventListener('change', function() {
              fixedAmount.disabled = !this.checked;
              if (!this.checked) {
                fixedAmount.value = '';
              }
            });
          });
  </script>


