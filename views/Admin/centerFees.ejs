<!DOCTYPE html>
<html lang="ar" dir="rtl">

    <%- include("./partials/head.ejs") %>
<style>
.spinner {
   width: 56px;
   height: 56px;
   display: grid;
   border: 4.5px solid #0000;
   border-radius: 50%;
   border-color: #dbdcef #0000;
   animation: spinner-e04l1k 1s infinite linear;
}

.spinner::before,
.spinner::after {
   content: "";
   grid-area: 1/1;
   margin: 2.2px;
   border: inherit;
   border-radius: 50%;
}

.spinner::before {
   border-color: #ff9847 #0000;
   animation: inherit;
   animation-duration: 0.5s;
   animation-direction: reverse;
}

.spinner::after {
   margin: 8.9px;
}

.attendance-card {
    transition: all 0.3s ease;
}

.attendance-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.collected-badge {
    position: absolute;
    bottom: 20px;
    left: 10px;
    z-index: 10;
}

.collect-btn {
    background-color: #28a745 !important;
    border: none;
    color: white;
    padding: 8px 16px;
    border-radius: 5px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.collect-btn:hover {
    background-color: #218838 !important;
    transform: scale(1.05);
}

.collect-btn:disabled {
    background-color: #6c757d !important;
    cursor: not-allowed;
    transform: none;
}

.details-btn {
  background-color: #17a2b8 !important;
  border: none;
  color: white;
  padding: 8px 16px;
  border-radius: 5px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.details-btn:hover {
  background-color: #138496 !important;
  transform: scale(1.05);
}

/* Toast positioning to avoid navbar */
.toast-container {
    z-index: 9999 !important;
}

.toast-container.position-fixed.bottom-0.end-0 {
    bottom: 20px !important;
    right: 20px !important;
    left: auto !important;
}

@keyframes spinner-e04l1k {
   100% {
      transform: rotate(1turn);
   }
}

/* Limit logs to ~5 rows then scroll */
.logs-scroll {
  max-height: 300px;
  overflow-y: auto;
}
</style>

<body class="g-sidenav-show rtl  bg-gray-100">
    <%- include("./partials/aside.ejs") %>

    <!-- Main content -->
  <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg ">
   
    <!-- Navbar -->
    <nav class="navbar navbar-main navbar-expand-lg px-0 mx-3 shadow-none border-radius-xl" id="navbarBlur" data-scroll="true">
      <div class="container-fluid pt-1 px-3">
        <h4>Center Fees Collection</h4>
      </div>
    </nav>
    <!-- End Navbar -->
    
    <div class="container-fluid py-2">
      <div class="row">
        <div class="col-lg-12">
          
          <!-- Filter Form -->
          <div class="row">
            <div class="col-md-12 mb-lg-0 mb-4">
              <form id="filterForm">
                <div class="card mt-4">
                  <div class="card-header pb-0 p-3">
                    <div class="row">
                      <div class="col-6 d-flex align-items-center">
                        <h5 class="mb-0">Filter Sessions</h5>
                      </div>
                      <div class="col-6 text-start">
                        <button type="submit" class="btn bg-gradient-dark mb-0" id="filterBTN">
                          <i class="material-symbols-rounded text-sm">search</i>&nbsp;&nbsp;Filter
                        </button>
                      </div>
                    </div>
                  </div>
                  <div class="card-body p-3">
                    <div class="row">
                      <div class="col-md-3">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="date" class="form-control border border-2 p-2" id="startDate" name="startDate">
                      </div>
                      <div class="col-md-3">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="date" class="form-control border border-2 p-2" id="endDate" name="endDate">
                      </div>
                      <div class="col-md-3">
                        <label class="form-label">Period</label>
                        <select class="form-control border border-2 p-2" id="period" name="period">
                          <option value="custom" selected>Custom</option>
                          <option value="today">Today</option>
                          <option value="week">This Week</option>
                          <option value="month">This Month</option>
                          <option value="year">This Year</option>
                        </select>
                      </div>
                      <div class="col-md-3">
                        <label for="collected" class="form-label">Collection Status</label>
                        <select class="form-control border border-2 p-2" id="collected" name="collected">
                          <option value="">All Sessions</option>
                          <option value="false">Pending Collection</option>
                          <option value="true">Already Collected</option>
                        </select>
                      </div>
                      <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="button" class="btn bg-gradient-success mb-0" id="collectSelectedBtn" style="display: none;">
                          <i class="material-symbols-rounded text-sm">payments</i>&nbsp;&nbsp;Collect Selected
                        </button>
                        <button type="button" class="btn bg-gradient-primary mb-0" id="collectAllBtn">
                          <i class="material-symbols-rounded text-sm">done_all</i>&nbsp;&nbsp;Collect All (Period)
                        </button>
                      </div>
                    </div>
                  </div>
                  <div id="spinner" class="spinner mx-auto d-none"></div>
                </div>
              </form>
            </div>
          </div>

          <!-- Summary Cards -->
          <div class="row">
            <div class="col-md-3 mb-4">
              <div class="card text-center">
                <div class="card-body">
                  <h6 class="mb-2">Total Sessions</h6>
                  <h4 class="text-primary" id="totalSessions">--</h4>
                </div>
              </div>
            </div>
            <div class="col-md-3 mb-4">
              <div class="card text-center">
                <div class="card-body">
                  <h6 class="mb-2">Total Center Fees</h6>
                  <h4 class="text-info" id="totalCenterFees">--</h4>
                </div>
              </div>
            </div>
            <div class="col-md-3 mb-4">
              <div class="card text-center">
                <div class="card-body">
                  <h6 class="mb-2">Collected</h6>
                  <h4 class="text-success" id="totalCollected">--</h4>
                </div>
              </div>
            </div>
            <div class="col-md-3 mb-4">
              <div class="card text-center">
                <div class="card-body">
                  <h6 class="mb-2">Pending</h6>
                  <h4 class="text-warning" id="totalPending">--</h4>
                </div>
              </div>
            </div>
          </div>

          <!-- Dashboard-like Cards -->
          <div class="row">
            <div class="col-lg-3 col-sm-6 mb-lg-0 mb-4">
              <div class="card">
                <div class="card-header d-flex justify-content-between p-3 pt-2">
                  <div class="icon icon-md icon-shape bg-gradient-success shadow-success text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">trending_up</i>
                  </div>
                  <div class="text-start pt-1">
                    <p class="text-sm mb-0 text-capitalize">Center Revenue</p>
                    <h4 class="mb-0" id="totalCenterRevenue">0</h4>
                  </div>
                </div>
                <hr class="dark horizontal my-0">
                <div class="card-footer p-3">
                  <p class="mb-0 text-start"><span class="text-success text-sm font-weight-bolder ms-1">Center Fees </span>from Attendance</p>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-sm-6 mb-lg-0 mb-4">
              <div class="card">
                <div class="card-header d-flex justify-content-between p-3 pt-2">
                  <div class="icon icon-md icon-shape bg-gradient-danger shadow-danger text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">receipt_long</i>
                  </div>
                  <div class="text-start pt-1">
                    <p class="text-sm mb-0 text-capitalize">Center Expenses</p>
                    <h4 class="mb-0" id="totalExpenses">0</h4>
                  </div>
                </div>
                <hr class="dark horizontal my-0">
                <div class="card-footer p-3">
                  <p class="mb-0 text-start"><span class="text-danger text-sm font-weight-bolder ms-1">Center Bills </span>and Expenses</p>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-sm-6 mb-lg-0 mb-4">
              <div class="card">
                <div class="card-header d-flex justify-content-between p-3 pt-2">
                  <div class="icon icon-md icon-shape bg-gradient-warning shadow-warning text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">store</i>
                  </div>
                  <div class="text-start pt-1">
                    <p class="text-sm mb-0 text-capitalize">Canteen Revenue</p>
                    <h4 class="mb-0" id="totalCanteenIn">0</h4>
                  </div>
                </div>
                <hr class="dark horizontal my-0">
                <div class="card-footer p-3">
                  <p class="mb-0 text-start"><span class="text-warning text-sm font-weight-bolder ms-1">Revenue </span>from Canteen</p>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-sm-6 mb-lg-0 mb-4">
              <div class="card">
                <div class="card-header d-flex justify-content-between p-3 pt-2">
                  <div class="icon icon-md icon-shape bg-gradient-secondary shadow-secondary text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">star</i>
                  </div>
                  <div class="text-start pt-1">
                    <p class="text-sm mb-0 text-capitalize">Employee Bonuses</p>
                    <h4 class="mb-0" id="totalEmployeeKPIs">0</h4>
                  </div>
                </div>
                <hr class="dark horizontal my-0">
                <div class="card-footer p-3">
                  <p class="mb-0 text-start"><span class="text-secondary text-sm font-weight-bolder ms-1">Bonuses </span>for Employees</p>
                </div>
              </div>
            </div>
            <div class="col-lg-3 col-sm-6 mb-lg-0 mb-4">
              <div class="card">
                <div class="card-header d-flex justify-content-between p-3 pt-2">
                  <div class="icon icon-md icon-shape bg-gradient-info shadow-info text-center border-radius-lg">
                    <i class="material-symbols-rounded opacity-10">account_balance_wallet</i>
                  </div>
                  <div class="text-start pt-1">
                    <p class="text-sm mb-0 text-capitalize">Center Net Profit</p>
                    <h4 class="mb-0" id="netProfit">0</h4>
                  </div>
                </div>
                <hr class="dark horizontal my-0">
                <div class="card-footer p-3">
                  <p class="mb-0 text-start"><span class="text-info text-sm font-weight-bolder ms-1">Revenue - Expenses</span></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Collection Logs (Top) -->
          <div class="row mt-4">
            <div class="col-md-12">
              <div class="card">
                <div class="card-header pb-0 px-3 d-flex align-items-center justify-content-between">
                  <h6 class="mb-0">Collection Logs</h6>
                  <button type="button" class="btn btn-sm btn-outline-dark" id="refreshLogsBtn">
                    <i class="material-symbols-rounded" style="font-size:16px;vertical-align:middle;">refresh</i>
                    Refresh
                  </button>
                </div>
                <div class="card-body pt-3 p-3">
                  <div class="table-responsive logs-scroll">
                    <table class="table align-items-center mb-0">
                      <thead>
                        <tr>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Date</th>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Period</th>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Teacher</th>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Sessions</th>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Total Center Fees</th>
                          <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Collected By</th>
                        </tr>
                      </thead>
                      <tbody id="collectionLogsBody">
                        <!-- Logs will be populated here -->
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Attendance Records -->
          <div class="row">
            <div class="col-md-12">
              <div class="card">
                <div class="card-header pb-0 px-3">
                  <h6 class="mb-0">Attendance Sessions</h6>
                </div>
                <div class="card-body pt-4 p-3">
                  <div id="spinner2" class="spinner mx-auto d-none"></div>
                  <div id="attendanceRecords" class="row">
                    <!-- Records will be populated here -->
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </main>

  <!--   Core JS Files   -->
  <script src="/js/adminJS/centerFees.js"></script>
  <script src="../assets/js/core/popper.min.js"></script>
  <script src="../assets/js/core/bootstrap.min.js"></script>
  <script src="../assets/js/plugins/perfect-scrollbar.min.js"></script>
  <script src="../assets/js/plugins/smooth-scrollbar.min.js"></script>

  <script>
    var win = navigator.platform.indexOf('Win') > -1;
    if (win && document.querySelector('#sidenav-scrollbar')) {
      var options = {
        damping: '0.5'
      }
      Scrollbar.init(document.querySelector('#sidenav-scrollbar'), options);
    }
  </script>
  <!-- Github buttons -->
  <script async defer src="https://buttons.github.io/buttons.js"></script>
  <!-- Control Center for Material Dashboard: parallax effects, scripts for the example pages etc -->
  <script src="../assets/js/material-dashboard.min.js?v=3.2.0"></script>
</body>

</html>
